{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$CLAUDE_TOOL_RESULT_FILE_PATH\"; if [[ \"$f\" == *.py ]]; then uv run ruff check --fix \"$f\" && uv run ruff format \"$f\"; fi'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run pytest -q 2>&1 | tail -5"
          }
        ]
      }
    ]
  }
}
